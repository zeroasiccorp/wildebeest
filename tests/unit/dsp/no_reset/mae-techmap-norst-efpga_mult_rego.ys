# yosys -m wildebeest -s mae-techmap-norst-efpga_mult_rego.ys
# Plain $dff (no reset): output register absorbed, clk connected, resetn tied 1'b1
read_verilog <<EOF
module efpga_mult_rego_norst_map_inst
  # (
     parameter INPUT_WIDTH = 18,
     parameter OUTPUT_WIDTH = 36
     )
   (
    input                                   clk,
    input signed [(INPUT_WIDTH-1):0]        a,
    input signed [(INPUT_WIDTH-1):0]        b,
    output reg [(OUTPUT_WIDTH-1):0]         y
    );

   always @(posedge clk) begin
      y <= a * b;
   end

endmodule
EOF

synth_fpga -partname z1010
select -assert-count 1 */t:efpga_mult_rego
select -assert-count 1 */t:efpga_mult_rego %x:+[clk] */w:clk %i
select -assert-count 0 */t:efpga_mult_rego %x:+[resetn] */w:resetn %i
