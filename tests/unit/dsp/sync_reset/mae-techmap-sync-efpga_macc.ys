# yosys -m wildebeest -s mae-techmap-sync-efpga_macc.ys
# Synchronous reset: $sdff not absorbed; post-adder still packed but no
# feedback (accumulate register outside DSP), degrades to efpga_mult_addc
read_verilog <<EOF
module efpga_macc_sync_map_inst
  # (
     parameter INPUT_WIDTH = 18,
     parameter OUTPUT_WIDTH = 40
     )
   (
    input                                   clk,
    input                                   reset,
    input signed [(INPUT_WIDTH-1):0]        a,
    input signed [(INPUT_WIDTH-1):0]        b,
    output reg [(OUTPUT_WIDTH-1):0]         y
    );

   wire signed [(2*INPUT_WIDTH-1):0] product;

   assign product = a * b;

   always @(posedge clk) begin
      if (reset) begin
         y <= 'h0;
      end
      else begin
         y <= y + product;
      end
   end

endmodule
EOF

synth_fpga -partname z1010
select -assert-count 1 */t:efpga_mult_addc
select -assert-count 0 */t:efpga_macc
select -assert-count 0 */t:efpga_mult_addc %x:+[clk] */w:clk %i
